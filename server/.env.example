# ============================================================================
# DEVELOPMENT MODE (ENVIRONMENT=development):
# ============================================================================
# DATABASE_URL and SECRET_KEY are OPTIONAL in development mode.
# If not provided, the server will use safe development defaults:
#   - DATABASE_URL: postgresql+asyncpg://claim_dev:claim_dev_password@localhost/claim_dev
#   - SECRET_KEY: randomly generated (changes each restart, tokens won't persist)
#
# For a persistent development setup, uncomment and set these values:

# DATABASE_URL=postgresql+asyncpg://claim_dev:claim_dev_password@localhost/claim_dev
# SECRET_KEY=dev_secret_key_at_least_32_characters_long_for_testing

# ============================================================================
# PRODUCTION MODE (ENVIRONMENT=production or staging):
# ============================================================================
# DATABASE_URL and SECRET_KEY are REQUIRED. Server will not start without them.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit the real SECRET_KEY to git!

# DATABASE_URL=postgresql+asyncpg://claim_user:STRONG_PASSWORD@db.internal:5432/claim_prod
# SECRET_KEY=GENERATE_WITH_SECRETS_MODULE_64_CHARS

# World name (first server is Euterpe)
WORLD_NAME=Euterpe

# Simulation tick interval (seconds per game tick, 1.0 = real-time)
TICK_INTERVAL=1.0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin API key (required for /admin endpoints - MUST be changed in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=changeme-admin-key

# Environment (development|production)
ENVIRONMENT=development

# Log level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO
