# Database connection (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost/claim_dev

# JWT secret key (MUST be set to a secure random value in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme-in-production

# World name (first server is Euterpe)
WORLD_NAME=Euterpe

# Simulation tick interval (seconds per game tick, 1.0 = real-time)
TICK_INTERVAL=1.0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin API key (required for /admin endpoints - MUST be changed in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=changeme-admin-key

# Environment (development|production)
ENVIRONMENT=development

# Log level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO
